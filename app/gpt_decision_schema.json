          "timing": { "type": "string", "minLength": 1 },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "EV-012", "EV-048", "EV-021", "EV-024", "EV-033", "EV-056", "EV-057",
                "EV-060", "EV-061", "EV-062", "EV-063", "EV-064", "EV-065"
              ]
            }
          }
        },
        "required": [
          "requirement_id",
          "category",
          "title",
          "status",
          "required_or_conditional",
          "and_or_relation",
          "valid_at_bid_deadline",
          "joint_venture_supplement_allowed",
          "timing",
          "evidence_ids"
